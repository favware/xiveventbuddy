{
	"name": "xiveventbuddy",
	"version": "2.0.0",
	"description": "A user friendly first discord bot to host your XIV events.",
	"author": "Jeroen Claassens <support@favware.tech>",
	"license": "Apache-2.0",
	"module": "dist/xiveventbuddy.mjs",
	"private": true,
	"type": "module",
	"imports": {
		"#lib/*": "./dist/lib/*.mjs",
		"#root/*": "./dist/*.mjs",
		"#utils/*": "./dist/lib/util/*.mjs",
		"#lib/env": "./dist/lib/env/index.mjs"
	},
	"scripts": {
		"start": "node --preserve-symlinks --enable-source-maps dist/xiveventbuddy.mjs",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"prisma:generate": "prisma generate",
		"build": "tsdown",
		"watch": "tsdown --watch",
		"clean": "rimraf dist/",
		"typecheck": "tsc -b src",
		"dev": "tsdown --watch --onSuccess \"yarn start\""
	},
	"prisma": {
		"seed": "unrun prisma/initial-data-seed.ts"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sapphire/decorators": "^6.2.0",
		"@sapphire/discord.js-utilities": "^7.3.3",
		"@sapphire/fetch": "^3.0.5",
		"@sapphire/framework": "^5.5.0",
		"@sapphire/plugin-i18next": "^8.0.0",
		"@sapphire/plugin-logger": "^4.1.0",
		"@sapphire/plugin-scheduled-tasks": "^10.0.4",
		"@sapphire/utilities": "^3.18.2",
		"@skyra/env-utilities": "^2.0.1",
		"@skyra/jaro-winkler": "^1.1.1",
		"@skyra/start-banner": "^2.0.2",
		"bufferutil": "^4.1.0",
		"bullmq": "^5.79.1",
		"colorette": "^2.0.20",
		"date-fns": "^4.4.0",
		"discord.js": "^14.26.4",
		"figlet": "^1.11.0",
		"gradient-string": "^3.0.0",
		"utf-8-validate": "^6.0.6",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@favware/discord-application-emojis-manager": "^1.1.1",
		"@sapphire/prettier-config": "^2.0.0",
		"@sapphire/ts-config": "^5.0.3",
		"@types/figlet": "^1.7.0",
		"@types/gradient-string": "^1.1.6",
		"@types/node": "^24.13.2",
		"@types/pg": "^8.20.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.5.0",
		"eslint-config-neon": "^0.5.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"prettier-plugin-prisma": "^5.0.0",
		"prisma": "^7.8.0",
		"rimraf": "^6.1.3",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"unrun": "^0.3.1"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"*.{mjs,js,ts}": "eslint --fix"
	},
	"packageManager": "yarn@4.12.0"
}
